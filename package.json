{
  "name": "wordpress-salts",
  "displayName": "WordPress Salts",
  "description": "Offline WordPress salt key generation for PHP, YAML and DotEnv files",
  "version": "1.5.0",
  "publisher": "idleberg",
  "license": "MIT",
  "author": {
    "name": "Jan T. Sott",
    "url": "http://github.com/idleberg"
  },
  "main": "./lib/index.js",
  "scripts": {
    "compile": "npm run build",
    "build": "concurrently --prefix-colors 'blue,green' 'npm:build:*'",
    "build:code": "tsdown",
    "build:image": "sharp resize 1024 1024 --input src/logo.svg --output resources/logo.png",
    "dev": "tsdown --watch",
    "lint": "biome check",
    "prepare": "lefthook install",
    "test": "npm run lint",
    "vscode:prepublish": "npm run build"
  },
  "keywords": [
    "wordpress",
    "wordpress salts",
    "cryptography"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/idleberg/vscode-wordpress-salts"
  },
  "homepage": "https://github.com/idleberg/vscode-wordpress-salts#readme",
  "bugs": {
    "url": "https://github.com/idleberg/vscode-wordpress-salts/issues"
  },
  "icon": "resources/logo.png",
  "galleryBanner": {
    "color": "#21759b",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:dotenv",
    "onLanguage:json",
    "onLanguage:json5",
    "onLanguage:jsonc",
    "onLanguage:php",
    "onLanguage:yaml"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "WordPress Salts",
      "properties": {
        "wordpress-salts.saltLength": {
          "type": "number",
          "default": 64,
          "minimum": 64,
          "maximum": 4096,
          "description": "Default length of salts, between 64 and 4096 characters",
          "order": 1
        },
        "wordpress-salts.jsonIndentation": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Default indentation of JSON strings",
          "order": 2
        },
        "wordpress-salts.alignPHP": {
          "type": "boolean",
          "default": true,
          "description": "Align definitions for better visual grepping",
          "order": 3
        }
      }
    },
    "commands": [
      {
        "command": "extension.wordpress-salts.insert",
        "title": "WordPress Salts: Insert"
      }
    ],
    "keybindings": [
      {
        "key": "ctrl+alt+w",
        "when": "editorFocus",
        "command": "extension.wordpress-salts.insert"
      }
    ]
  },
  "dependencies": {
    "vscode-get-config": "^0.5.0",
    "vscode-insert-text": "^1.1.0",
    "wp-salts": "^5.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@idleberg/configs": "^0.3.1",
    "@types/node": "^24.7.0",
    "@types/vscode": "^1.50.0",
    "concurrently": "^9.2.1",
    "sharp-cli": "^5.2.0",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3"
  }
}
